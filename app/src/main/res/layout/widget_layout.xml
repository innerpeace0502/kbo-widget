<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- 시계+날짜 행: 시합 중(라이브)에는 Provider가 숨겨 세로 공간(~55dp)을 확보하고,
         경기 전·종료·취소·경기없음에는 다시 표시. TextClock은 시스템이 자동 갱신 -->
    <LinearLayout
        android:id="@+id/layout_clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextClock
            android:id="@+id/tv_time_hm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="HH:mm"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFF"
            android:textSize="42sp"
            android:textStyle="bold"/>

        <TextClock
            android:id="@+id/tv_time_sec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour=":ss"
            android:format24Hour=":ss"
            android:textColor="#AAAAAA"
            android:textSize="26sp"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="2dp"/>

        <TextClock
            android:id="@+id/tv_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:format12Hour="yyyy.MM.dd EEE"
            android:format24Hour="yyyy.MM.dd EEE"
            android:textColor="#777777"
            android:textSize="13sp"
            android:gravity="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- 로고 55→48dp, 팀명·점수 36→30sp — 5칸 최소폭(338dp)에서도
             '두산 10 vs 9 삼성' 같은 최장 조합이 좌우 아웃라인에 닿지 않는 크기 -->
        <ImageView
            android:id="@+id/iv_logo_away"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/tv_away"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KIA"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_score_away"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginStart="7dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_vs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="vs"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginHorizontal="6dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"/>

        <TextView
            android:id="@+id/tv_score_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginEnd="7dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KT"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_logo_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="7dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tv_game_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18:30 시작"
            android:textColor="#777777"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_center_sep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#555555"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_stadium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="수원 KT위즈파크"
            android:textColor="#777777"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_live_inning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5555"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- 채널: LIVE 바로 아래 표시. 상황 카드 위로 올려 하단 잘림 방지 -->
    <TextView
        android:id="@+id/tv_channel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFD700"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="2dp"/>

    <!-- 경기 상황: 한 줄 바 [이닝·LIVE/채널·베이스·B·S·O] (SituationDrawer.makeWidgetBar, status=1에만 VISIBLE)
         상황카드+LIVE행+채널행을 한 줄로 합쳐 세로 높이를 크게 줄임(잘림 방지). 비트맵 700x130(≈5.4:1).
         마지막 요소라 하단 여백은 root padding(12dp)이 담당 — 아웃라인에 닿지 않음 -->
    <ImageView
        android:id="@+id/iv_situation"
        android:layout_width="330dp"
        android:layout_height="66dp"
        android:layout_gravity="center"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_situation"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:contentDescription="경기 상황"
        android:visibility="gone"/>

    <TextView android:id="@+id/tv_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game1"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game2"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game3"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game4"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game5"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_updated"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>

</LinearLayout>