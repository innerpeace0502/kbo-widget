<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- 좌측상단 시계(HH:mm:ss) 제거 — 확보한 세로 공간으로 라이브 콘텐츠가
         위젯 아웃라인에 닿지 않게 됨. 날짜만 우측 상단에 유지 (TextClock은 시스템 자동 갱신) -->
    <TextClock
        android:id="@+id/tv_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:format12Hour="yyyy.MM.dd EEE"
        android:format24Hour="yyyy.MM.dd EEE"
        android:textColor="#777777"
        android:textSize="13sp"
        android:gravity="end"
        android:layout_marginBottom="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- 로고 55→48dp, 팀명·점수 36→30sp — 5칸 최소폭(338dp)에서도
             '두산 10 vs 9 삼성' 같은 최장 조합이 좌우 아웃라인에 닿지 않는 크기 -->
        <ImageView
            android:id="@+id/iv_logo_away"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:id="@+id/tv_away"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KIA"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_score_away"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginStart="7dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_vs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="vs"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginHorizontal="6dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="3dp"/>

        <TextView
            android:id="@+id/tv_score_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFD700"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginEnd="7dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KT"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_logo_home"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="7dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tv_game_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="18:30 시작"
            android:textColor="#777777"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_center_sep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textColor="#555555"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_stadium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="수원 KT위즈파크"
            android:textColor="#777777"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tv_live_inning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5555"
            android:textSize="16sp"
            android:layout_marginStart="8dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- 채널: LIVE 바로 아래 표시. 상황 카드 위로 올려 하단 잘림 방지 -->
    <TextView
        android:id="@+id/tv_channel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFD700"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="2dp"/>

    <!-- 경기 상황: 이닝 + 주자 다이아몬드 + B·S·O (SituationDrawer 비트맵, status=1에만 VISIBLE)
         위젯 칸에 맞게 높이 축소 + 비트맵 비율(≈3.07:1) 유지해 카드를 꽉 채움.
         마지막 요소라 하단 여백은 root padding(12dp)이 담당 — 아웃라인에 닿지 않음 -->
    <ImageView
        android:id="@+id/iv_situation"
        android:layout_width="190dp"
        android:layout_height="62dp"
        android:layout_gravity="center"
        android:layout_marginBottom="0dp"
        android:background="@drawable/bg_situation"
        android:padding="6dp"
        android:scaleType="fitCenter"
        android:contentDescription="경기 상황"
        android:visibility="gone"/>

    <TextView android:id="@+id/tv_title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game1"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game2"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game3"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game4"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_game5"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>
    <TextView android:id="@+id/tv_updated"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:visibility="gone"/>

</LinearLayout>