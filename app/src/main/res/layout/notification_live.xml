<?xml version="1.0" encoding="utf-8"?>
<!-- 라이브 고정 알림 확장 뷰 — [팀 점수 : 점수 팀 | 이닝] + 한 줄 상황 바 + 현재 투/타.
     DecoratedCustomViewStyle 안에 들어가므로 배경/앱 아이콘 행은 시스템이 그린다. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="12dp"
    android:paddingStart="12dp"
    android:paddingEnd="68dp">

    <!-- 팀명·스코어 중앙정렬 (이닝은 아래 상황 바 왼쪽에 표시되므로 별도 뱃지 없음) -->
    <TextView
        android:id="@+id/tv_n_score"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="KIA 5 : 3 SSG"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <!-- 한 줄 상황 바 (SituationDrawer.makeNotificationBar: 이닝·주자·B·S·O 3요소) -->
    <ImageView
        android:id="@+id/iv_n_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:scaleType="fitCenter"
        android:contentDescription="경기 상황"/>

    <TextView
        android:id="@+id/tv_n_players"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_gravity="center_horizontal"
        android:text=""
        android:textSize="12sp"/>
</LinearLayout>
